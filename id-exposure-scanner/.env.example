# ============================================================
# ID Exposure Scanner - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values as needed.

# --- Request Configuration ---
REQUEST_TIMEOUT=15
REQUEST_DELAY_MIN=1.5
REQUEST_DELAY_MAX=4.0
MAX_RESULTS_PER_SOURCE=20
MAX_RETRIES=2

# --- Output Directory ---
OUTPUT_DIR=./output

# --- Logging Level (DEBUG, INFO, WARNING, ERROR) ---
LOG_LEVEL=INFO

# --- Optional API Keys (for enhanced results) ---

# Bing Web Search API v7 (Azure Cognitive Services)
# BING_API_KEY=

# GitHub Personal Access Token (increases rate limit + enables code search)
# GITHUB_TOKEN=

# Reddit OAuth Application (https://www.reddit.com/prefs/apps)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# Truecaller API (enterprise/authorized access only)
# TRUECALLER_API_KEY=

# HaveIBeenPwned API key (optional)
# HIBP_API_KEY=
